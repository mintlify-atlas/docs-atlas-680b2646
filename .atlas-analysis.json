  "keyFeatures": [
    "Multi-AI Provider Support (OpenAI, Anthropic, Google, AWS Bedrock, Azure, and more)",
    "AI Agents with Model Context Protocol (MCP) Support",
    "Code Interpreter with Secure Sandboxed Execution",
    "Generative UI with Code Artifacts",
    "Web Search Integration",
    "Multi-User Authentication (OAuth2, LDAP, Email)",
    "Image Generation and Editing",
    "Conversation Management with Branching",
    "File Upload and Analysis",
    "Multilingual Interface (30+ languages)",
    "Resumable Streams",
    "Speech-to-Text and Text-to-Speech",
    "Custom Endpoints and Actions",
    "Presets and Prompt Management",
    "Role-Based Access Control"
